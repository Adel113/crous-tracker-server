# ── Villes à surveiller (séparées par des virgules) ─────────
CITIES=Paris,ile-de-france

# ── Loyer maximum en euros ───────────────────────────────────
MAX_PRICE=800

# ── Intervalle de vérification en minutes ───────────────────
INTERVAL_MINUTES=5

# ── Email de destination ─────────────────────────────────────
EMAIL_TO=adelsidiahmed2020@gmail.com

# ── Configuration SMTP ───────────────────────────────────────
# Gmail recommandé → utilise un "Mot de passe d'application"
# (pas ton mot de passe habituel)
# Guide : https://support.google.com/accounts/answer/185833

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=adelsidiahmed2020@gmail.com
SMTP_PASS=maeo paxx wnbi ytpl

# ── Port du serveur HTTP (ne pas changer sur Railway) ────────
PORT=3000
